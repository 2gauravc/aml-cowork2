# Set true to run the credential-free, fixture-backed local demo.
DEMO_MODE=true

# Live mode only: set DEMO_MODE=false and provide these values.
KYCBASEURL=https://api.knowyourcustomer.dev
KYCCLIENTID=
KYCCLIENTSECRET=
OPENAI_API_KEY=
TAVILY_API_KEY=

# Optional model overrides. All workflows default to GPT-5.6.
OPENAI_MODEL=gpt-5.6
OPENAI_CSP_MODEL=gpt-5.6
OPENAI_CASE_REVIEW_MODEL=gpt-5.6
OPENAI_DOCUMENT_MODEL=gpt-5.6
OPENAI_POLICY_MODEL=gpt-5.6

# Optional live-mode S3 document storage.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_DOCUMENT_BUCKET_URL=
